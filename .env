# ─────────────────────────────────────────────
# FitRAG — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ─────────────────────────────────────────────

# ── REQUIRED ─────────────────────────────────
# Get your free key at: https://console.groq.com
GROQ_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXX

# ── OPTIONAL OVERRIDES ────────────────────────
# Groq model (default: llama3-70b-8192)
# Options: llama3-70b-8192 | llama3-8b-8192 | mixtral-8x7b-32768 | gemma2-9b-it
# GROQ_MODEL=llama3-70b-8192

# Embedding model (default: all-MiniLM-L6-v2)
# EMBED_MODEL=all-MiniLM-L6-v2

# Chunk size in characters (default: 512)
# CHUNK_SIZE=512

# Chunk overlap (default: 64)
# CHUNK_OVERLAP=64

# Number of retrieved chunks (default: 6)
# TOP_K=6
